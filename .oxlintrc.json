{
  "ignorePatterns": ["**/node_modules/**", "**/.next/**", "**/dist/**", "**/coverage/**"],
  "plugins": ["typescript", "import", "promise"],
  "rules": {
    "no-default-export": "error",
    "import/no-cycle": "error"
  },
  "categories": {
    "correctness": "error"
  },
  "overrides": [
    {
      "files": ["apps/web/**/*.{ts,tsx}"],
      "plugins": ["react", "react-perf", "jsx-a11y"]
    },
    {
      "files": ["**/*.test.{ts,tsx}", "**/*.spec.{ts,tsx}"],
      "plugins": ["vitest"]
    },
    {
      "files": [
        "**/page.tsx",
        "**/layout.tsx",
        "**/loading.tsx",
        "**/error.tsx",
        "**/not-found.tsx",
        "**/template.tsx",
        "**/default.tsx",
        "**/next.config.ts",
        "**/vitest.config.ts",
        "**/playwright.config.ts",
        "**/prisma.config.ts"
      ],
      "rules": {
        "no-default-export": "off"
      }
    }
  ]
}
