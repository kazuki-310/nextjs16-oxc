{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [],
  "plugins": ["react", "react-perf", "import", "jsx-a11y", "promise", "typescript"],
  "env": {
    "node": true,
    "browser": true
  },
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-default-export": "error",
    "typescript/explicit-function-return-type": ["error"]
  },
  "overrides": [
    {
      "files": ["src/components/ui/*.tsx", "src/hooks/*.ts"],
      "rules": {
        "typescript/explicit-function-return-type": "off"
      }
    },
    {
      "files": [
        "page.tsx",
        "layout.tsx",
        "loading.tsx",
        "error.tsx",
        "not-found.tsx",
        "next.config.ts",
        "vitest.config.ts",
        "playwright.config.ts",
        "postcss.config.mjs"
      ],
      "rules": {
        "no-default-export": "off"
      }
    }
  ]
}
