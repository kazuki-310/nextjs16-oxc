{
  "name": "nextjs16-oxc",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm --filter web build",
    "check": "turbo run type-check && oxlint && oxfmt --check",
    "dev": "pnpm --filter web dev",
    "fmt": "oxfmt --check",
    "fmt:fix": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "postinstall": "lefthook install",
    "start": "pnpm --filter web start",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "lefthook": "^2.1.1",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "turbo": "^2.8.16"
  },
  "engines": {
    "node": "24.14.0"
  },
  "packageManager": "pnpm@10.32.1"
}
