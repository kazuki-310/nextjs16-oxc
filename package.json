{
  "name": "nextjs16-oxc",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm --filter web build",
    "check": "turbo run type-check && oxlint && oxfmt --check",
    "dev": "turbo run dev",
    "fmt": "oxfmt --check",
    "fmt:fix": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "postinstall": "lefthook install",
    "prisma:generate": "pnpm --filter @packages/database prisma:generate",
    "prisma:migrate:dev": "pnpm --filter @packages/database prisma:migrate:dev",
    "start": "pnpm --filter web start",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter web test:e2e",
    "test:e2e:ui": "pnpm --filter web test:e2e:ui",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "lefthook": "^2.1.1",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "turbo": "^2.8.16",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": "24.14.0"
  },
  "packageManager": "pnpm@10.32.1"
}
