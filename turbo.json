{
  "$schema": "https://turborepo.dev/schema.json",
  "globalEnv": ["DATABASE_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "type-check": {
      "dependsOn": ["^type-check"]
    },
    "test": {
      "cache": false
    },
    "prisma:generate": {
      "cache": false
    },
    "prisma:migrate:dev": {
      "cache": false
    },
    "prisma:migrate:deploy": {
      "cache": false
    },
    "//#lint": {},
    "//#lint:fix": {
      "cache": false
    },
    "//#fmt": {},
    "//#fmt:fix": {
      "cache": false
    }
  }
}
